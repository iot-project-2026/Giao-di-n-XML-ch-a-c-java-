<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_music">
    <LinearLayout
        android:id="@+id/ln1"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#123458"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/family"
            android:textColor="#ab886d"
            android:textSize="20sp"/>
        <Button
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/btnUser"
            android:drawableTop="@drawable/user"
            android:layout_gravity="center"
            app:backgroundTint="@null"
            android:background="@android:color/transparent"
            android:contentDescription="@string/user_profile"/>
    </LinearLayout>
    <TextView
        android:id="@+id/txtNowPlaying"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ln1"
        android:padding="10dp"
        android:text="@string/now_playing"
        android:textSize="18sp"/>

    <Button
        android:id="@+id/btnPlayPause"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtNowPlaying"
        android:text="@string/pause"/>

    <ListView
        android:id="@+id/listMusic"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnPlayPause"
        android:layout_above="@id/bottom_navigation"/>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#123458"
        app:menu="@menu/bottom_nav_menu"
        app:itemTextColor="@drawable/selector"
        app:itemIconTint="@drawable/selector">
    </com.google.android.material.bottomnavigation.BottomNavigationView>
</RelativeLayout>